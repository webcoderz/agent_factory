# Workbench / LLM (agent_ext.workbench with --use-openai-chat-model)
# Copy to .env and set values. load_dotenv() runs at startup.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o

# Optional: parallel limits (defaults shown)
# MAX_PARALLEL_SUBAGENTS=4
# MAX_PARALLEL_MODEL_CALLS=2
